{
  "info": {
    "name": "TROPEX R2 Uploads",
    "description": "Endpoints para subida de archivos a Cloudflare R2 desde TROPEX",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://django-backend-production-bd80.up.railway.app",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "upload_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "public_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "object_key",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (obtiene access_token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test-uploads@tropex.com\",\n  \"password\": \"testpass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.tokens && json.tokens.access) {",
                  "    pm.collectionVariables.set('access_token', json.tokens.access);",
                  "    console.log('✓ access_token guardado');",
                  "} else {",
                  "    console.log('✗ No se encontró tokens.access en la respuesta');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (crea usuario de prueba)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test-uploads@tropex.com\",\n  \"password\": \"testpass123\",\n  \"password_confirm\": \"testpass123\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"Uploads\",\n  \"phone\": \"+595981123456\",\n  \"role_slug\": \"ganadero\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register", ""]
            }
          }
        }
      ]
    },
    {
      "name": "R2 Uploads",
      "item": [
        {
          "name": "1. Pedir URL pre-firmada (presigned-url)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document_type\": \"access_map\",\n  \"filename\": \"mapa-test.jpg\",\n  \"content_type\": \"image/jpeg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/uploads/presigned-url/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "uploads", "presigned-url", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.upload_url) {",
                  "    pm.collectionVariables.set('upload_url', json.upload_url);",
                  "    pm.collectionVariables.set('public_url', json.public_url);",
                  "    pm.collectionVariables.set('object_key', json.object_key);",
                  "    console.log('✓ URLs guardadas');",
                  "    console.log('upload_url length:', json.upload_url.length);",
                  "    const sig = json.upload_url.split('X-Amz-Signature=')[1];",
                  "    if (sig) {",
                  "      const cleanSig = sig.split('&')[0];",
                  "      console.log('Signature:', cleanSig);",
                  "      console.log('Signature length:', cleanSig.length, '(debe ser 64)');",
                  "    }",
                  "  } else {",
                  "    console.log('✗ No se encontraron URLs en la respuesta');",
                  "  }"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Subir archivo a R2 (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "image/jpeg"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": ""
              }
            },
            "url": {
              "raw": "{{upload_url}}",
              "host": [
                "{{upload_url}}"
              ],
              "path": []
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const url = pm.collectionVariables.get('upload_url');",
                  "console.log('=== URL a usar en PUT ===');",
                  "console.log(url);",
                  "console.log('URL length:', url ? url.length : 'NULL');",
                  "if (url) {",
                  "  const sig = url.split('X-Amz-Signature=')[1];",
                  "  if (sig) {",
                  "    const cleanSig = sig.split('&')[0];",
                  "    console.log('Signature:', cleanSig);",
                  "    console.log('Signature length:', cleanSig.length, '(debe ser 64)');",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Verificar archivo subido (GET public_url)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{public_url}}",
              "host": [
                "{{public_url}}"
              ],
              "path": []
            }
          }
        },
        {
          "name": "4. Eliminar archivo (DELETE) - solo admin",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object_key\": \"{{object_key}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/uploads/object/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "uploads", "object", ""]
            }
          }
        }
      ]
    }
  ]
}
