              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.results && json.results.length > 0) {",
                  "    const firstReq = json.results[0];",
                  "    pm.collectionVariables.set('change_request_id', String(firstReq.id));",
                  "    console.log('✓ change_request_id guardado:', firstReq.id);",
                  "    console.log('Total solicitudes:', json.count);",
                  "  } else {",
                  "    console.log('No hay solicitudes para guardar ID');",
                  "  }"
                ]
              }
            }
