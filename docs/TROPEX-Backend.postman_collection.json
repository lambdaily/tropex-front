            },
            "url": {
              "raw": "{{baseUrl}}/api/user-change-requests/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user-change-requests", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Cloudflare R2 Uploads",
      "item": [
        {
          "name": "1. POST /api/uploads/presigned-url/ (pedir URL pre-firmada)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.upload_url) {",
                  "    pm.collectionVariables.set('upload_url', json.upload_url);",
                  "    pm.collectionVariables.set('public_url', json.public_url);",
                  "    pm.collectionVariables.set('object_key', json.object_key);",
                  "    console.log('✓ URLs guardadas');",
                  "    console.log('Signature length:', json.upload_url.split('X-Amz-Signature=')[1]?.split('&')[0]?.length, '(debe ser 64)');",
                  "  } else {",
                  "    console.log('✗ No se encontraron URLs en la respuesta');",
                  "  }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document_type\": \"access_map\",\n  \"filename\": \"mapa-test.jpg\",\n  \"content_type\": \"image/jpeg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/uploads/presigned-url/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "uploads", "presigned-url", ""]
            }
          }
        },
        {
          "name": "2. PUT {{upload_url}} (subir archivo a R2)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "image/jpeg"
              }
            ],
            "body": {
              "mode": "file",
              "file": {}
            },
            "url": {
              "raw": "{{upload_url}}",
              "host": ["{{upload_url}}"],
              "path": []
            }
          }
        },
        {
          "name": "3. GET {{public_url}} (verificar archivo)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{public_url}}",
              "host": ["{{public_url}}"],
              "path": []
            }
          }
        },
        {
          "name": "4. DELETE /api/uploads/object/ (eliminar - solo admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object_key\": \"{{object_key}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/uploads/object/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "uploads", "object", ""]
            }
          }
        }
      ]
    },
