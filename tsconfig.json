{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode — Vite resuelve los módulos, TS solo chequea tipos */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",

    /* Chequeo de tipos */
    "strict": true,
    "noFallthroughCasesInSwitch": true,

    /* Alias '@' -> ./src (igual que en vite.config.ts) */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/imports"]
}
